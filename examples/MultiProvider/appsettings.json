{
  "Llm": {
    "DefaultProvider": "openai/latest-large",
    "Providers": {
      "openai/latest-small": {
        "Provider": "openai",
        "ApiBase": "https://api.openai.com/v1",
        "ApiKey": "${OPENAI_API_KEY}",
        "Model": "gpt-4o-mini",
        "Enabled": true
      },
      "openai/latest-large": {
        "Provider": "openai",
        "ApiBase": "https://api.openai.com/v1",
        "ApiKey": "${OPENAI_API_KEY}",
        "Model": "gpt-4o",
        "Enabled": true
      },
      "cerebras/fast-large": {
        "Provider": "cerebras",
        "ApiBase": "https://api.cerebras.ai/v1",
        "ApiKey": "${CEREBRAS_API_KEY}",
        "Model": "llama-3.3-70b",
        "Enabled": true
      },
      "cerebras/glm-4.6": {
        "Provider": "cerebras",
        "ApiBase": "https://api.cerebras.ai/v1",
        "ApiKey": "${CEREBRAS_API_KEY}",
        "Model": "zai-glm-4.6",
        "Enabled": true
      },
      "openrouter/free": {
        "Provider": "openrouter",
        "ApiBase": "https://openrouter.ai/api/v1",
        "ApiKey": "${OPENROUTER_API_KEY}",
        "Model": "openai/gpt-oss-20b:free",
        "Enabled": true
      },
      "openrouter/kimi-free": {
        "Provider": "openrouter",
        "ApiBase": "https://openrouter.ai/api/v1",
        "ApiKey": "${OPENROUTER_API_KEY}",
        "Model": "moonshotai/kimi-k2.6:free",
        "Enabled": true
      },
      "openrouter/glm-free": {
        "Provider": "openrouter",
        "ApiBase": "https://openrouter.ai/api/v1",
        "ApiKey": "${OPENROUTER_API_KEY}",
        "Model": "z-ai/glm-4.5-air:free",
        "Enabled": true
      },
      "azure/production": {
        "Provider": "azure",
        "ApiKey": "${AZURE_OPENAI_KEY}",
        "ApiBase": "${AZURE_OPENAI_ENDPOINT}",
        "DeploymentName": "${AZURE_OPENAI_DEPLOYMENT}",
        "Enabled": true
      },
      "ollama/local": {
        "Provider": "ollama",
        "ApiBase": "http://localhost:11434",
        "Model": "gpt-oss:20b",
        "Enabled": true
      }
    }
  }
}
